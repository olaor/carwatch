#!/usr/bin/env bash
# fw-tui – Launch the FinnWatch TUI.
#
# On first run this script creates a Python virtual environment and installs all
# required dependencies automatically.  Subsequent runs reuse the existing venv
# (fast path: just check imports).
#
# Two modes:
#   Source-tree / dev:  venv lives at <repo-root>/.venv, lib/ is on PYTHONPATH.
#   System install (deb): venv lives at ~/.local/share/finnwatch/venv; the
#                         modules are already on the system Python path so no
#                         extra PYTHONPATH manipulation is needed.
#
# Usage:
#   fw-tui [--db /path/to/finnwatch.db]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(dirname "$SCRIPT_DIR")"
DEPS=(textual requests beautifulsoup4)

# ── Detect run context ────────────────────────────────────────────────────────
if [[ -f "$ROOT/lib/finnwatch_tui.py" ]]; then
    # Source-tree / development run.
    VENV="$ROOT/.venv"
    EXTRA_PYTHONPATH="$ROOT/lib"
    VENV_OPTS=()
else
    # System-wide install (deb package): use a per-user venv so we never need
    # root and the system Python is kept clean.  --system-site-packages lets
    # the venv Python reach finnwatch_tui and finnwatch_core which are
    # installed into /usr/lib/python3/dist-packages/ by the deb package.
    VENV="${XDG_DATA_HOME:-$HOME/.local/share}/finnwatch/venv"
    EXTRA_PYTHONPATH=""
    VENV_OPTS=(--system-site-packages)
fi

PYTHON="$VENV/bin/python"
PIP="$VENV/bin/pip"

# ── 1. Create venv if it does not exist ───────────────────────────────────────
if [[ ! -x "$PYTHON" ]]; then
    echo "Creating virtual environment at $VENV …"
    mkdir -p "$(dirname "$VENV")"
    python3 -m venv "${VENV_OPTS[@]}" "$VENV"
    echo "Virtual environment created."
fi

# ── 2. Install / verify dependencies ─────────────────────────────────────────
if ! "$PYTHON" -c "import textual, requests, bs4" 2>/dev/null; then
    echo "Installing dependencies: ${DEPS[*]} …"
    "$PIP" install --quiet "${DEPS[@]}"
    echo "Dependencies installed."
fi

# ── 3. Launch the TUI ────────────────────────────────────────────────────────
if [[ -n "$EXTRA_PYTHONPATH" ]]; then
    PYTHONPATH="$EXTRA_PYTHONPATH${PYTHONPATH:+:$PYTHONPATH}" \
        exec "$PYTHON" -c "import finnwatch_tui; finnwatch_tui.main()" "$@"
else
    exec "$PYTHON" -c "import finnwatch_tui; finnwatch_tui.main()" "$@"
fi
