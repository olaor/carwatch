#!/usr/bin/env bash
# fw-tui – Launch the FinnWatch TUI.
#
# On first run this script creates a Python virtual environment under .venv/
# inside the project root and installs all required dependencies automatically.
# Subsequent runs reuse the existing venv (fast path: just check imports).
#
# Usage:
#   bin/fw-tui [--db /path/to/finnwatch.db]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(dirname "$SCRIPT_DIR")"
VENV="$ROOT/.venv"
PYTHON="$VENV/bin/python"
PIP="$VENV/bin/pip"
DEPS=(textual requests beautifulsoup4)

# ── 1. Create venv if it does not exist ───────────────────────────────────────
if [[ ! -x "$PYTHON" ]]; then
    echo "Creating virtual environment at $VENV …"
    python3 -m venv "$VENV"
    echo "Virtual environment created."
fi

# ── 2. Install / verify dependencies ─────────────────────────────────────────
if ! "$PYTHON" -c "import textual, requests, bs4" 2>/dev/null; then
    echo "Installing dependencies: ${DEPS[*]} …"
    "$PIP" install --quiet "${DEPS[@]}"
    echo "Dependencies installed."
fi

# ── 3. Launch the TUI ────────────────────────────────────────────────────────
PYTHONPATH="$ROOT/lib${PYTHONPATH:+:$PYTHONPATH}" \
    exec "$PYTHON" -c "import finnwatch_tui; finnwatch_tui.main()" "$@"
